

generator client_python {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
  output = "../app/prisma_client"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// -------------------------------------------------------------
// Better Auth Core Tables
// -------------------------------------------------------------

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  sessions      Session[]
  accounts      Account[]
  searches      Search[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// -------------------------------------------------------------
// Application Specific Tables
// -------------------------------------------------------------

model Search {
  id         String    @id @default(uuid())
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  query      String
  category   String
  createdAt  DateTime  @default(now())

  articles   Article[]
  insights   Insight[]

  @@map("search")
}

model Article {
  id              String   @id @default(uuid())
  searchId        String
  search          Search   @relation(fields: [searchId], references: [id], onDelete: Cascade)
  title           String
  content         String?
  source          String
  url             String
  publishedAt     DateTime?
  sentiment       String?  // positive, negative, neutral
  sentimentScore  Float?
  biasLabel       String?  // LEFT, CENTER, RIGHT
  sourceBias      String?  // LEFT, CENTER, RIGHT (from static registry)
  deviationScore  Float?   // anomaly distance between source and article bias
  entities        Json?    // Extracted NER entities
  createdAt       DateTime @default(now())

  @@map("article")
}

model Insight {
  id                  String   @id @default(uuid())
  searchId            String
  search              Search   @relation(fields: [searchId], references: [id], onDelete: Cascade)
  avgSentiment        Float
  topKeywords         Json     // Array of strings or object
  biasDistribution    Json     // Counts for left/center/right
  dataQualityScore    Float
  totalArticles       Int
  validArticles       Int
  duplicatesRemoved   Int
  missingContent      Int
  datasetMetrics      Json?    // Stores Source Diversity, Geographic Diversity, Coverage Imbalance
  narrativeSummary    String?  // Generated AI narrative
  leftWingSummary     String?  // Generated AI narrative for Left-wing articles
  rightWingSummary    String?  // Generated AI narrative for Right-wing articles
  entitySentiment     Json?    // Extracted entities and their sentiment
  driftMetrics        Json?    // Model drift and uncertainty metrics
  createdAt           DateTime @default(now())

  @@map("insight")
}

// -------------------------------------------------------------
// Phase 2: Global Claim Database (Evidence-Based Intelligence)
// -------------------------------------------------------------

model Claim {
  id                  String   @id @default(uuid())
  canonicalClaim      String
  claimType           String?  @default("EVENT") // EVENT, NUMERIC, BIOGRAPHICAL, OPINION, ANALYSIS, PREDICTION, QUOTE
  qualityScore        Float?   @default(0)
  embedding           Unsupported("vector(384)")
  confidence          Float
  consensusScore      Float?   @default(0)
  contradictionScore  Float?   @default(0)
  createdAt           DateTime @default(now())
  clusterId           String?
  cluster             ClaimCluster? @relation(fields: [clusterId], references: [id])
  evidence            Evidence[]

  @@map("claim")
}

model Evidence {
  id              String   @id @default(uuid())
  claimId         String
  articleId       String
  sentence        String
  source          String
  url             String
  publishedAt     DateTime
  stance          String
  claim           Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@map("evidence")
}

model Event {
  id              String @id @default(uuid())
  title           String
  description     String?
  importanceScore Float? @default(0)
  createdAt       DateTime @default(now())
  claimClusters   ClaimCluster[]

  @@map("event")
}

model ClaimCluster {
  id              String @id @default(uuid())
  title           String
  canonicalClaim  String?
  consensusScore  Float? @default(0)
  eventId         String?
  event           Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  claims          Claim[]

  @@map("claim_cluster")
}

// -------------------------------------------------------------
// Development Infrastructure
// -------------------------------------------------------------

model LLMCache {
  id         String   @id @default(uuid())
  promptHash String   @unique
  model      String
  stage      String   @default("unknown")
  response   String
  createdAt  DateTime @default(now())

  @@map("llm_cache")
}

model LLMUsage {
  id               String   @id @default(uuid())
  stage            String
  model            String
  cached           Boolean  @default(false)
  promptTokens     Int?     @default(0)
  completionTokens Int?     @default(0)
  createdAt        DateTime @default(now())

  @@map("llm_usage")
}

// -------------------------------------------------------------
// Phase 3: Consensus and Contradiction Engine (Prepared Schema)
// -------------------------------------------------------------

model ConsensusFact {
  id              String   @id @default(uuid())
  factStatement   String
  confidenceScore Float    @default(0)
  sourceCount     Int      @default(0)
  firstSeenAt     DateTime
  lastSeenAt      DateTime
  createdAt       DateTime @default(now())

  @@map("consensus_fact")
}

model ContradictionPair {
  id                 String   @id @default(uuid())
  claimAId           String
  claimBId           String
  contradictionType  String   // DIRECT, NUMERIC, TIMELINE, CONTEXTUAL
  confidenceScore    Float    @default(0)
  resolved           Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@map("contradiction_pair")
}
